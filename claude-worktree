#!/bin/bash
set -e
name="$1"
if [ -z "$name" ]; then
    echo "Usage: claude-worktree <name>"
    echo "Reads agent prompt from stdin."
    exit 1
fi
dir=".claude/worktrees/$name"
branch="worktree-$name"
base="main"

prompt="$(cat)"
if [ -z "$prompt" ]; then
    echo "Error: no prompt provided on stdin"
    exit 1
fi

if [ -d "$dir" ]; then
    echo "Error: worktree $dir already exists"
    exit 1
fi
git worktree add "$dir" -b "$branch" "$base"

if [ "$AGENT" = "codex" ]; then
    cmd="pnpx @openai/codex $(printf '%q' "$prompt")"
else
    cmd="claude --permission-mode acceptEdits $(printf '%q' "$prompt")"
fi

tmux new-session -d -s "$name" -c "$(pwd)/$dir" "$cmd"

echo "Started tmux session '$name'"
