/*
Adapted for RetroArch from Flyguy's "Apple II-Like Artifact Colors" from shadertoy:
https://www.shadertoy.com/view/llyGzR
*/

/* COMPATIBILITY 
   - HLSL compilers
   - Cg   compilers
   - FX11 compilers
*/

//#pragma parameter F_COL "F Col" 0.25 0.25 0.5 0.25
#ifdef PARAMETER_UNIFORM
uniform float F_COL;
#else
#define F_COL 0.25
#endif

#include "../../../compat_includes.inc"
uniform COMPAT_Texture2D(decal) : TEXUNIT0;
uniform float4x4 modelViewProj;

struct out_vertex
{
	float4 position : COMPAT_POS;
	float2 texCoord : TEXCOORD0;
#ifndef HLSL_4
	float4 Color    : COLOR;
#endif
};

out_vertex main_vertex(COMPAT_IN_VERTEX)
{
	out_vertex OUT;
#ifdef HLSL_4
	float4 position = VIN.position;
	float2 texCoord = VIN.texCoord;
#else
	OUT.Color = color;
#endif
	OUT.position = mul(modelViewProj, position);
	OUT.texCoord = texCoord;
	
	return OUT;
}

//Modulator

float3x3 rgb2yiq = float3x3(0.299, 0.596, 0.211,
                    0.587,-0.274,-0.523,
                    0.114,-0.322, 0.312);

//Complex oscillator, Fo = Oscillator freq., Fs = Sample freq., n = Sample index
float2 Oscillator(float Fo, float Fs, float n)
{
    float tau = 6.283185308;
    float phase = (tau*Fo*floor(n))/Fs;
    return float2(cos(phase),sin(phase));
}

float4 main_fragment(COMPAT_IN_FRAGMENT) : COMPAT_Output
{
    float2 texCoord = VOUT.texCoord;
    float2 texture_size = COMPAT_texture_size;
    float2 video_size = COMPAT_video_size;
    float2 output_size = COMPAT_output_size;

    float Fs = video_size.x;
    float Fcol = Fs * F_COL;
    float2 fc = float2((texCoord.xy * output_size.xy) * (texture_size.xy / video_size.xy));
    float n = floor(fc.x);
    
    float3 cRGB = COMPAT_Sample(decal, texCoord.xy).rgb;
    float3 cYIQ = mul(cRGB, rgb2yiq);
    
    float2 cOsc = Oscillator(Fcol, Fs, n);
    
    float sig = cYIQ.x + dot(cOsc, cYIQ.yz);

    return float4(sig, 0., 0., 1.);
}
COMPAT_END
