shaders = "5"

shader0 = "../motionblur/shaders/feedback.slang"
filter_linear0 = false

#shader1 = "../shaders/lcd-cgwg/lcd-grid-v2.slang"
shader1 = ../handheld/shaders/authentic_gbc/to_lin_fast.slang
filter_linear1 = false
scale_type1 = source
srgb_framebuffer1 = true

shader2 = ../handheld/shaders/authentic_gbc/authentic_gbc_fast.slang
filter_linear2 = false
scale_type2 = viewport

shader3 = "../handheld/shaders/pixel_transparency/pixel_transparency.slang"
filter_linear3 = true
scale_type3 = viewport

shader4 = "../handheld/shaders/frontlit-reflective.slang"
filter_linear4 = true
scale_type4 = viewport
float_framebuffer4 = true

PT_SHADOW_OFFSET_X = 1.0
PT_SHADOW_OFFSET_Y = 1.0
PT_PALETTE = 1.0
PT_POLARIZER = 0.0
PT_HIGHLIGHTS = 0.0


textures = "dirt"
dirt = ../handheld/console-border/resources/dirty-glass.png
dirt_linear = true
dirt_wrap_mode = repeat
