    else if (phase_index == 6)
    {
        result = V4(-0.0012251337, 0.00022690487, 0.027825622, 0.03732215);
        result += V4(-0.04285592, 0.032137595, 0.038754895, -0.02355173) * inp_0_0_0;
        result += V4(-0.004131254, -0.02382099, 0.25016397, -0.12174118) * inp_0_1_0;
        result += V4(0.0735344, -0.0069333985, 0.13412257, 0.009131789) * inp_0_2_0;
        result += V4(-0.1240915, -0.03458629, -0.26730254, -0.016279092) * inp_0_0_1;
        result += V4(0.18329464, 0.028393282, -0.36701146, -0.19068788) * inp_0_1_1;
        result += V4(-0.024145238, 0.009975768, 0.19560878, 0.028512679) * inp_0_2_1;
        result += V4(0.15766142, 0.0027180829, -0.05573896, 0.027096108) * inp_0_0_2;
        result += V4(-0.16811287, -0.0067967945, -0.0039285277, 0.09254344) * inp_0_1_2;
