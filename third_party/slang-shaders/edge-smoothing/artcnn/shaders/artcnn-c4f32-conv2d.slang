        result += V4(0.010548004, -0.20011833, -0.04840889, 0.0013898173) * inp_0_0_0;
        result += V4(0.0059627173, -0.20631418, -0.00069781486, 0.0459049) * inp_0_1_0;
        result += V4(0.033312477, -0.025722466, -0.026746217, -0.04564476) * inp_0_2_0;
        result += V4(-0.014621813, -0.21758953, 0.019623566, 0.047015008) * inp_0_0_1;
        result += V4(-0.06413715, 0.51320696, 0.08983417, -0.046426684) * inp_0_1_1;
        result += V4(0.0075579984, 0.12064985, 0.016194692, 0.013250015) * inp_0_2_1;
