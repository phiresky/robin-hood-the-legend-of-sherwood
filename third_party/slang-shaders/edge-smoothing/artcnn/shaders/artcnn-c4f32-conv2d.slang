        result += V4(-0.00665234, 0.033866473, 0.0008190067, -0.010575895) * inp_0_0_0;
        result += V4(0.020025166, -0.03722349, -0.057728786, -0.011012458) * inp_0_1_0;
        result += V4(-0.01922099, 0.00394599, 0.06210346, 0.024697691) * inp_0_2_0;
        result += V4(-0.011220356, -0.025387427, -0.006051429, -0.04012146) * inp_0_0_1;
        result += V4(-0.05235222, 0.0395031, 0.10571346, 0.0034405796) * inp_0_1_1;
        result += V4(0.06397409, -0.010557341, -0.09178192, 0.017660808) * inp_0_2_1;
        result += V4(0.02457124, -0.0076957955, 0.014449284, 0.042195566) * inp_0_0_2;
        result += V4(0.02437401, -0.008127155, -0.046804044, 0.030843958) * inp_0_1_2;
        result += V4(-0.04345333, 0.011609933, 0.018816916, -0.05850401) * inp_0_2_2;
    }
    else if (phase_index == 5)
    {
        result = V4(0.00030683735, 8.590639e-05, 0.0011228231, -0.0003569378);
        result += V4(-0.022652062, 0.00013649276, 0.02822522, 0.07449741) * inp_0_0_0;
        result += V4(0.0036423136, -0.009622607, 0.019767707, -0.027863344) * inp_0_1_0;
        result += V4(0.0047593894, 0.006462716, -0.042175345, -0.07397786) * inp_0_2_0;
        result += V4(-0.020696703, -0.0044155456, -0.0014935521, -0.09446131) * inp_0_0_1;
        result += V4(0.015226903, 0.020063741, -0.04530335, -0.008880305) * inp_0_1_1;
        result += V4(0.017827976, -0.008952561, 0.070653915, 0.1327598) * inp_0_2_1;
        result += V4(0.034625176, 0.006859942, -0.030471254, 0.023261195) * inp_0_0_2;
        result += V4(0.010331661, -0.0090735, 0.028933162, 0.029970676) * inp_0_1_2;
        result += V4(-0.043197736, -0.0015350957, -0.029467264, -0.055419024) * inp_0_2_2;
