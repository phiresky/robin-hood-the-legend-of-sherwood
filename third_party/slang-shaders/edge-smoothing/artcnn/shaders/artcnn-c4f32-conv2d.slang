#pragma format R16G16B16A16_SFLOAT

layout(push_constant) uniform Push
{
    vec4 artcnn_yuvSize;
    vec4 OutputSize;
    uint FrameCount;
} params;

layout(std140, set = 0, binding = 0) uniform UBO
{
    mat4 MVP;
} global;

#pragma stage vertex
layout(location = 0) in vec4 Position;
layout(location = 1) in vec2 TexCoord;
layout(location = 0) out vec2 vTexCoord;

void main()
{
    gl_Position = global.MVP * Position;
    vTexCoord = TexCoord;
}

#pragma stage fragment
layout(location = 0) in vec2 vTexCoord;
layout(location = 0) out vec4 FragColor;
layout(set = 0, binding = 2) uniform sampler2D artcnn_yuv;

#define V4 vec4
#define M4 mat4
#include "artcnn-common.inc"

void main()
{
    ivec2 output_pixel = artcnn_output_pixel(params.OutputSize.xy);
    const ivec2 block_size = ivec2(4, 2);
    ivec2 base = output_pixel / block_size;
    ivec2 phase = output_pixel % block_size;
    int phase_index = phase.y * 4 + phase.x;
    float inp_0_0_0 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(-1, -1));
    float inp_0_1_0 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(0, -1));
    float inp_0_2_0 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(1, -1));
    float inp_0_0_1 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(-1, 0));
    float inp_0_1_1 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(0, 0));
    float inp_0_2_1 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(1, 0));
    float inp_0_0_2 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(-1, 1));
    float inp_0_1_2 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(0, 1));
    float inp_0_2_2 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(1, 1));
    vec4 result = vec4(0.0);
    if (phase_index == 0)
    {
        result = V4(0.00029719682, -0.0014720066, 8.162458e-05, -0.08328656);
        result += V4(-0.03823595, -0.06965141, 0.057807874, -0.03770885) * inp_0_0_0;
        result += V4(0.018986901, 0.19749214, -0.058446474, 0.0005390018) * inp_0_1_0;
        result += V4(-0.013422343, -0.11547432, 0.026615717, 0.041784476) * inp_0_2_0;
        result += V4(0.0689497, -0.0018005769, -0.016152069, -0.18712986) * inp_0_0_1;
        result += V4(-0.01775814, -0.03113816, -0.03785366, 0.12528929) * inp_0_1_1;
        result += V4(-0.006083886, 0.029609155, 0.009611117, 0.13607746) * inp_0_2_1;
        result += V4(-0.014355586, 0.07624153, -0.02976815, -0.005620912) * inp_0_0_2;
        result += V4(-0.026223402, -0.15436348, 0.08110813, 0.062548615) * inp_0_1_2;
        result += V4(0.028161632, 0.07029042, -0.032889232, 0.08372451) * inp_0_2_2;
    }
    else if (phase_index == 1)
    {
        result = V4(-0.0013031764, -0.0004398726, -0.0018822165, 0.0008068186);
        result += V4(0.015057175, 0.06048061, 0.082558945, 0.092912) * inp_0_0_0;
        result += V4(0.05168004, -0.04345358, 0.05731101, -0.112354495) * inp_0_1_0;
        result += V4(-0.036297154, 0.015417843, -0.12451414, -0.045905355) * inp_0_2_0;
        result += V4(-0.0038541774, -0.030741142, -0.09108843, -0.13427265) * inp_0_0_1;
        result += V4(-0.08127109, 0.047959723, 0.04351332, 0.16019344) * inp_0_1_1;
        result += V4(0.034648877, -0.05474974, 0.030381644, 0.06842291) * inp_0_2_1;
        result += V4(-0.017405175, -0.0568071, -0.007846174, 0.04576768) * inp_0_0_2;
        result += V4(0.02778629, 0.016930273, -0.097900495, -0.04946804) * inp_0_1_2;
        result += V4(0.011026718, 0.046053432, 0.10855338, -0.025562346) * inp_0_2_2;
    }
    else if (phase_index == 2)
    {
        result = V4(0.0028612618, 0.003681991, 0.000933314, 0.0032181526);
        result += V4(-0.020247115, 0.019655116, 0.056145806, -0.015038169) * inp_0_0_0;
        result += V4(0.03074084, 0.08463694, -0.14912683, 0.0039739753) * inp_0_1_0;
        result += V4(-0.036160152, -0.01721598, 0.041164864, -0.023051519) * inp_0_2_0;
        result += V4(-0.07710085, -0.20408772, -0.05183754, -0.078683704) * inp_0_0_1;
        result += V4(-0.33751717, 0.536409, 0.35220885, 0.09567589) * inp_0_1_1;
        result += V4(0.0006857658, -0.33222365, -0.21403433, 0.10935543) * inp_0_2_1;
        result += V4(0.12179155, -0.071092024, 0.00995113, 0.012694526) * inp_0_0_2;
        result += V4(0.2607293, 0.005812557, -0.14984728, -0.1283972) * inp_0_1_2;
        result += V4(0.049164157, -0.013817462, 0.105999656, 0.01731948) * inp_0_2_2;
    }
    else if (phase_index == 3)
    {
        result = V4(-0.002406673, -0.06238555, -0.0003887231, 0.00088146876);
        result += V4(0.00070895697, 0.032472927, -0.013915315, -0.008157398) * inp_0_0_0;
        result += V4(-0.041764982, 0.19321719, -0.0020123976, -0.022692956) * inp_0_1_0;
        result += V4(0.04220856, 0.02334752, 0.036842328, 0.004516592) * inp_0_2_0;
        result += V4(0.00755459, 0.107427396, -0.029543161, 0.01352713) * inp_0_0_1;
        result += V4(-0.0198901, 0.241412, 0.020800307, 0.07489205) * inp_0_1_1;
        result += V4(0.0557781, 0.18318829, -0.030219302, -0.04099845) * inp_0_2_1;
