    else if (phase_index == 7)
    {
        result = V4(-0.0015319894, -0.0018427352, 0.008053138, -0.0005414844);
        result += V4(0.031542253, -0.20469837, -0.063453734, -0.0032535447) * inp_0_0_0;
        result += V4(-0.016106455, -0.1781373, -0.0011102876, 0.06547678) * inp_0_1_0;
        result += V4(0.058147494, -0.029121729, -0.050040793, -0.04488308) * inp_0_2_0;
        result += V4(-0.033560928, -0.1997352, 0.023148786, 0.058584824) * inp_0_0_1;
        result += V4(-0.08233455, 0.45768273, 0.09700763, -0.040784404) * inp_0_1_1;
        result += V4(-0.019785587, 0.1211534, 0.025009468, 0.020605747) * inp_0_2_1;
        result += V4(0.007459592, -0.049712658, -0.036610004, -0.06334075) * inp_0_0_2;
