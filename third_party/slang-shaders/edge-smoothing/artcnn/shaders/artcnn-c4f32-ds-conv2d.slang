        result += V4(-0.01464519, 0.03311998, 0.010902619, -0.01279907) * inp_0_0_0;
        result += V4(0.019495672, -0.034898777, -0.026697388, 0.011404317) * inp_0_1_0;
        result += V4(-0.026356589, 0.00029451968, 0.033806514, 0.026959537) * inp_0_2_0;
        result += V4(0.008567506, -0.011048174, 0.011949299, -0.077361114) * inp_0_0_1;
        result += V4(-0.05383461, 0.045259375, 0.08210071, -0.0028459746) * inp_0_1_1;
        result += V4(0.055974923, -0.008382856, -0.08225134, 0.014535179) * inp_0_2_1;
        result += V4(0.03452037, -0.030947132, 0.004355576, 0.069002606) * inp_0_0_2;
        result += V4(0.011390849, -0.008441289, -0.03809085, 0.03133412) * inp_0_1_2;
        result += V4(-0.031257354, 0.011784627, 0.0020454538, -0.061116938) * inp_0_2_2;
    }
    else if (phase_index == 5)
    {
        result = V4(-0.00024284767, -0.0012972294, 0.0031863682, 0.00032834132);
        result += V4(-0.040908635, -0.025981262, 0.01383108, 0.07238378) * inp_0_0_0;
        result += V4(0.040509567, 0.018556867, 0.020722749, -0.013207388) * inp_0_1_0;
        result += V4(-0.010994465, -0.021688106, -0.0065398365, -0.09380191) * inp_0_2_0;
        result += V4(-0.0327628, 0.017872581, 0.0018384313, -0.08896779) * inp_0_0_1;
        result += V4(0.023122977, 0.005187882, -0.030509144, -0.0011404202) * inp_0_1_1;
        result += V4(0.0054629077, 0.020477673, 0.06104786, 0.15381244) * inp_0_2_1;
        result += V4(0.044787146, 0.00027207384, -0.03402326, 0.017461464) * inp_0_0_2;
        result += V4(0.001377724, 0.004611562, 0.058313522, 0.02768396) * inp_0_1_2;
        result += V4(-0.032231078, -0.018028462, -0.09276276, -0.07440535) * inp_0_2_2;
    }
    else if (phase_index == 6)
    {
        result = V4(-0.002174482, 0.0018437742, 0.030196855, 0.035569318);
        result += V4(-0.05616352, 0.072983, 0.038269166, -0.02729853) * inp_0_0_0;
        result += V4(0.016469847, -0.044859093, 0.2269724, -0.11983737) * inp_0_1_0;
        result += V4(0.08664728, -0.028269285, 0.14066854, 0.005381753) * inp_0_2_0;
        result += V4(-0.13262774, -0.020343363, -0.2524551, -0.020579554) * inp_0_0_1;
        result += V4(0.16672969, 0.018529834, -0.33177933, -0.17501411) * inp_0_1_1;
        result += V4(-0.010302839, 0.0066588763, 0.17793381, 0.025041483) * inp_0_2_1;
        result += V4(0.18117039, -0.023446001, -0.06429693, 0.035361458) * inp_0_0_2;
        result += V4(-0.1737803, 0.0025161493, -0.011774367, 0.08865114) * inp_0_1_2;
