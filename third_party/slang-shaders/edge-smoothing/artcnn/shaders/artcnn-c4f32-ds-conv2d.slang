#pragma format R16G16B16A16_SFLOAT

layout(push_constant) uniform Push
{
    vec4 artcnn_yuvSize;
    vec4 OutputSize;
    uint FrameCount;
} params;

layout(std140, set = 0, binding = 0) uniform UBO
{
    mat4 MVP;
} global;

#pragma stage vertex
layout(location = 0) in vec4 Position;
layout(location = 1) in vec2 TexCoord;
layout(location = 0) out vec2 vTexCoord;

void main()
{
    gl_Position = global.MVP * Position;
    vTexCoord = TexCoord;
}

#pragma stage fragment
layout(location = 0) in vec2 vTexCoord;
layout(location = 0) out vec4 FragColor;
layout(set = 0, binding = 2) uniform sampler2D artcnn_yuv;

#define V4 vec4
#define M4 mat4
#include "artcnn-common.inc"

void main()
{
    ivec2 output_pixel = artcnn_output_pixel(params.OutputSize.xy);
    const ivec2 block_size = ivec2(4, 2);
    ivec2 base = output_pixel / block_size;
    ivec2 phase = output_pixel % block_size;
    int phase_index = phase.y * 4 + phase.x;
    float inp_0_0_0 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(-1, -1));
    float inp_0_1_0 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(0, -1));
    float inp_0_2_0 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(1, -1));
    float inp_0_0_1 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(-1, 0));
    float inp_0_1_1 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(0, 0));
    float inp_0_2_1 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(1, 0));
    float inp_0_0_2 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(-1, 1));
    float inp_0_1_2 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(0, 1));
    float inp_0_2_2 = artcnn_fetch_scalar(artcnn_yuv, params.artcnn_yuvSize, base + ivec2(1, 1));
    vec4 result = vec4(0.0);
    if (phase_index == 0)
    {
        result = V4(0.0021185656, -0.0025917033, 0.00018152398, -0.0806362);
        result += V4(-0.044257514, -0.0513465, 0.079141, -0.043819577) * inp_0_0_0;
        result += V4(0.0027947575, 0.2009357, -0.07563901, 0.0012847728) * inp_0_1_0;
        result += V4(0.0051169493, -0.11794144, 0.048943114, 0.043392256) * inp_0_2_0;
        result += V4(0.07755304, -0.034371294, -0.026062708, -0.18201138) * inp_0_0_1;
        result += V4(-0.0012315033, -0.026736414, -0.05571761, 0.10451194) * inp_0_1_1;
        result += V4(0.002525418, 0.017427761, 0.007466845, 0.12689897) * inp_0_2_1;
        result += V4(-0.025627134, 0.09190752, -0.010224698, -0.013412675) * inp_0_0_2;
        result += V4(-0.046121046, -0.15885709, 0.055776242, 0.057195663) * inp_0_1_2;
        result += V4(0.024080317, 0.08400124, -0.022874054, 0.08177703) * inp_0_2_2;
    }
    else if (phase_index == 1)
    {
        result = V4(0.0012814859, -0.00016921744, -0.0018398693, -8.1586724e-05);
        result += V4(0.04757426, 0.050669666, 0.10178185, 0.058637496) * inp_0_0_0;
        result += V4(0.047061644, -0.006915979, 0.058034, -0.0890527) * inp_0_1_0;
        result += V4(-0.020321894, 0.008222686, -0.13913725, -0.055665325) * inp_0_2_0;
        result += V4(-0.057027336, -0.017143741, -0.096126445, -0.118268624) * inp_0_0_1;
        result += V4(-0.049535774, 0.02399625, 0.045363322, 0.13902989) * inp_0_1_1;
        result += V4(-0.005224238, -0.06859187, 0.024963908, 0.10838056) * inp_0_2_1;
        result += V4(-0.017336847, -0.10223742, -0.0022247704, 0.040351685) * inp_0_0_2;
        result += V4(0.0043280465, 0.057968453, -0.11079095, -0.04624489) * inp_0_1_2;
        result += V4(0.04957048, 0.054826945, 0.12195052, -0.03633389) * inp_0_2_2;
    }
    else if (phase_index == 2)
    {
        result = V4(0.001750477, 0.008750652, -0.00045053518, 0.0026217822);
        result += V4(-0.019234963, 0.007829838, 0.037571393, -0.031596843) * inp_0_0_0;
        result += V4(0.021518636, 0.10186994, -0.11322811, 0.010657768) * inp_0_1_0;
        result += V4(-0.029544491, -0.02760813, 0.007080535, -0.017511794) * inp_0_2_0;
        result += V4(-0.08279917, -0.18892887, -0.014098004, -0.07197196) * inp_0_0_1;
