        result += V4(-0.0127232, -0.30963355, -0.15727162, 0.12049333) * inp_0_2_1;
        result += V4(0.12790212, -0.07070779, -0.028256971, -0.012137102) * inp_0_0_2;
        result += V4(0.24182852, 0.024160268, -0.11737531, -0.114679635) * inp_0_1_2;
        result += V4(0.06391722, -0.023002252, 0.09189042, 0.01251308) * inp_0_2_2;
    }
    else if (phase_index == 3)
    {
        result = V4(0.00023826386, -0.05482249, -0.00021923787, 0.002400302);
        result += V4(0.006564327, 0.038686175, -0.026568158, -0.027619388) * inp_0_0_0;
        result += V4(-0.053941067, 0.1862563, 0.00050362013, -0.024840856) * inp_0_1_0;
        result += V4(0.056523066, 0.029548714, 0.052265085, 0.019588495) * inp_0_2_0;
        result += V4(-0.0005614959, 0.11034771, -0.0651515, 0.042963233) * inp_0_0_1;
        result += V4(-0.030651037, 0.22450808, 0.0292341, 0.09326786) * inp_0_1_1;
        result += V4(0.06465616, 0.17814583, -0.024588088, -0.044403367) * inp_0_2_1;
