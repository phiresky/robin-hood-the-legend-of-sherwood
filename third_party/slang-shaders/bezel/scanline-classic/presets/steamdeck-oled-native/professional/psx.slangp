shader10 = ..\..\..\shaders\curve.slang
filter_linear10 = false
scale_type10 = source
scale10 = 1.0

shader11 = ..\..\..\shaders\color-wcg.slang
filter_linear11 = false
scale_type11 = source
scale11 = 1.0

shader12 = ..\..\..\shaders\bezel-wcg.slang
filter_linear12 = true
mipmap_input12 = true
scale12 = 1.0

textures = "BORDER"
BORDER_linear = true
BORDER_wrap_mode = clamp_to_edge
BORDER_mipmap = true


SYS_BANDWIDTH_R = 6.7
